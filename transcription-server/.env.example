# Whisper model to use: tiny, base, small, medium, large-v3
WHISPER_MODEL=medium

# Device: cpu or cuda
WHISPER_DEVICE=cpu

# Compute type: int8 (CPU), float16 (GPU), float32
WHISPER_COMPUTE_TYPE=int8

# Number of concurrent transcription workers (3-4 for 3-4 users)
WHISPER_WORKERS=4

# Server port
PORT=8765

# Model cache directory (optional)
MODEL_CACHE_DIR=./models
